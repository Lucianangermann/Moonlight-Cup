# --- Moonlight Cup Server ---
# Copy to .env and fill in real values. NEVER commit .env.

# Random hex string used to sign session cookies. Rotate to force logouts.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-64-hex-chars

# SQLite path (absolute or relative to server/)
DATABASE_PATH=moonlight_cup.db

# Single admin account
ADMIN_EMAIL=admin@example.com

# bcrypt hash, NOT plaintext. Generate via:
#   python -c "from flask_bcrypt import Bcrypt; print(Bcrypt().generate_password_hash('YOUR_PW').decode())"
ADMIN_PASSWORD_HASH=$2b$12$replace_with_real_bcrypt_hash

# Local Gunicorn bind port (Cloudflare Tunnel forwards to this)
PORT=5000
